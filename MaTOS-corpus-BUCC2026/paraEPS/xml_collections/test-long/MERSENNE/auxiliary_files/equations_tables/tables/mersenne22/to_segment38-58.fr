   7                                                                                        $\eta_{r} = \left( {1 - \frac{\phi}{\phi_{m}}} \right)^{- B\phi_{m}}$                                                                                                                                       Krieger et Dougherty [1959]

   8                                                                                        $\eta_{r} = \left( {1 - \frac{\phi}{\phi_{m}}} \right)^{- B\phi_{m}}$                                                                                                                                      Krieger et Dougherty [1959];
                                                                                                                                                                                                                                                                                               B = 2.5 pour les particules sphériques; pour
                                                                                                                                                                                                                                                                                                 les particules allongées, B pourrait être
                                                                                                                                                                                                                                                                                                                  modifié

   9                                               $\eta_{r} = \exp\left\{ {\left\lbrack \left( {2.5 + \frac{\phi}{\phi_{m} - \phi}} \right)^{\alpha} \right\rbrack \cdot \frac{\phi}{\phi_{m}}} \right\}$                                                                                                  Gay etal. [1969];
                                                                                                                                                                                                                                                                                                                 𝛼 = 0.48

   10                                                                        $\eta_{r} = \left( {1 - \alpha\frac{\frac{\phi}{\phi_{m}}}{1 - \frac{\phi}{\phi_{m}}}} \right)^{2}$                                                                                                                           Chong etal. [1971];
                                                                                                                                                                                                                                                                                                                 𝛼 = 0.75

   11                                                                        $\eta_{r} = \frac{1}{\left( {1 - \frac{\mathit{Φ}}{{\mathit{Φ}}_{m}}} \right)^{{\mathit{Φ}}_{m}}}$                                                                                                                        Wildemuth et Williams [1984]

   12                        $\eta_{r} = 1 + \frac{3\pi}{8}\frac{\beta}{\beta + 1}\left\lbrack {\frac{3 + 4.5\beta + \beta^{2}}{\beta + 1} - 3\left( {1 - \frac{1}{\beta}} \right)\ln\left( {\beta + 1} \right)} \right\rbrack$                                                                        Shapiro et Probstein [1992];
                                                                                                                                                                                                                                                        $\beta = \frac{\left( \frac{\phi}{\phi_{m}} \right)^{\frac{1}{3}}}{1 - \left( \frac{\phi}{\phi_{m}} \right)^{\frac{1}{3}}}$

   13   $\eta_{r} = \frac{1 + \varphi^{\delta}}{\left\{ {1 - \alpha \cdot \text{erf}\left\lbrack {\left( {\frac{\sqrt{\pi}}{2\alpha} \cdot \varphi} \right)\left( {1 + \varphi^{\dot{\gamma}}} \right)} \right\rbrack} \right\}^{B{\mathit{Φ}}_{m}}}$                                                         Costa [2005];
                                                                                                                                                                                                                                                                                                     $\varphi = \frac{\phi}{\phi_{m}}$

